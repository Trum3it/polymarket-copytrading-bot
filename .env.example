# Copy this file to `.env` and fill in your values:
# Never commit `.env` — it contains secrets.

# -----------------------------------------------------------------------------
# Required — wallet private key used to sign Polymarket CLOB requests
# -----------------------------------------------------------------------------
# 64 hex characters, with or without a 0x prefix.
# This must be the key for the wallet that holds (or controls) your trading USDC.
POLYMARKET_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Required — leader wallet to copy trades from
# -----------------------------------------------------------------------------
# Use the trader's Polymarket proxy/profile address (the on-chain address shown
# on their profile page), not their signing key.
# Example: LEADER_WALLET_ADDRESS=0x204f72f35326db932158cba6adff0b9a1da95e14
LEADER_WALLET_ADDRESS=

# -----------------------------------------------------------------------------
# Optional — Polymarket proxy / funder wallet address
# -----------------------------------------------------------------------------
# Leave blank if you trade directly from an EOA (MetaMask, hardware wallet, etc.).
# Set this if you signed up on polymarket.com with email / social login.
# PROXY_WALLET_ADDRESS=

# -----------------------------------------------------------------------------
# Copy trading settings
# -----------------------------------------------------------------------------

# Fixed USD amount per copied trade (default: 10). Ignored if COPY_RATIO is set.
COPY_USD=10

# Copy a fraction of the leader's trade size (0–1). When set, overrides COPY_USD.
# Example: COPY_RATIO=0.1 copies 10% of the leader's notional per trade.
# COPY_RATIO=

# Poll interval in milliseconds for checking leader trades (default: 2000)
POLL_MS=2000

# Max price slippage in basis points when placing live orders (default: 100 = 1%)
MAX_PRICE_SLIPPAGE_BPS=100

# Simulation mode. Set to false to place real orders on Polymarket.
# Default: true (safe — no real trades until you explicitly disable)
DRY_RUN=true

# Mirror leader SELL trades (default: true). Set to false to only copy BUYs.
COPY_SELLS=true

# Optional comma-separated slug prefixes to filter markets.
# Example: only copy 5m crypto markets:
# MARKET_FILTER=btc-updown-5m,eth-updown-5m,sol-updown-5m,xrp-updown-5m
# MARKET_FILTER=
